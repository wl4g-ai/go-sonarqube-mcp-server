{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "sonarqube-mcp-cli-list",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "env": {
                "SONARQUBE_URL": "https://httpbin.org/anything",
                "SONARQUBE_TOKEN": "your-token"
            },
            "args": [
                "-t",
                "cli",
                "list"
            ]
        },
        {
            "name": "sonarqube-mcp-search-sonar-issues-in-projects",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "env": {
                // "SONARQUBE_URL": "https://sonarqube.wl4g.com",
                "SONARQUBE_URL": "https://httpbin.org/anything",
                "SONARQUBE_TOKEN": "your-token"
            },
            "args": [
                "--verbose",
                "10",
                "--transport",
                "cli",
                "search_sonar_issues_in_projects",
                "--ps",
                "5",
                "--branch",
                "main",
                "--files",
                "service/src/main/java/com/wl4g/rengine/service/impl/sys/UploadServiceImpl.java"
            ]
        },
        {
            "name": "sonarqube-mcp-agg-search-issue-summary",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "env": {
                // "SONARQUBE_URL": "https://sonarqube.wl4g.com",
                "SONARQUBE_URL": "https://httpbin.org/anything",
                "SONARQUBE_TOKEN": "xxx"
            },
            "args": [
                "--verbose",
                "10",
                "--transport",
                "cli",
                "agg_search_issue_summary",
                "--ps",
                "5",
                "--branch",
                "main",
                "--key",
                "rengine:apiserver/src/main/java/com/wl4g/RengineApiServer.java"
            ]
        }
    ]
}